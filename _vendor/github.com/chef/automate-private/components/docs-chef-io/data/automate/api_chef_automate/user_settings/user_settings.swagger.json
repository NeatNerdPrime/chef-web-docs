        },
        "status": {
          "type": "string",
          "title": "Status of the request: \"processing\", \"completed\", \"error\", \"not_found\""
        },
        "file_size": {
          "type": "string",
          "title": "Human-readable file size (e.g., \"15.2 MB\") - only present when status is \"completed\""
        },
        "download_url": {
          "type": "string",
          "title": "Download URL for the log file - only present when status is \"completed\""
        },
        "error": {
          "type": "string",
          "title": "Error code - only present when status indicates an error\nPossible values: \"audit_disabled\", \"not_found\", \"no_requested_logs\""
        },
        "message": {
          "type": "string",
          "title": "Human-readable message describing the status or error"
