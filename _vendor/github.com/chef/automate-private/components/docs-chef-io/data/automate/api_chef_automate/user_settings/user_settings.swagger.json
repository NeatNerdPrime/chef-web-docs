          {
            "name": "to",
            "description": "End time for audit log retrieval (optional, default: now).",
            "in": "query",
            "required": false,
            "type": "string",
            "format": "date-time"
          },
          {
            "name": "order",
            "description": "Sort order for logs (optional, default: desc)\nValid values: asc, desc.",
            "in": "query",
            "required": false,
            "type": "string"
          }
        ],
        "tags": [
          "UserSettingsService"
        ]
      }
    },
    "/api/v0/audit/status": {
      "get": {
        "summary": "GetAuditLogsRequestStatus checks the status of an audit log request",
